.page {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.desc {
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.label {
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.value,
.json {
  background: #f3f4f6;
  border-radius: 16rpx;
  padding: 20rpx;
  word-break: break-all;
}

.json {
  font-family: monospace;
  white-space: pre-wrap;
}

.button {
  margin-top: 24rpx;
}

.success {
  border-left: 8rpx solid #22c55e;
}

.error {
  border-left: 8rpx solid #ef4444;
}
